# Copy this file to .env.local and fill in your own keys.
# Never commit .env.local — it's gitignored.
# On Vercel: add these in Project → Settings → Environment Variables.

# Script / copy (already used)
GEMINI_API_KEY=

# Video generation (e.g. Replicate — get token at https://replicate.com/account/api-tokens)
REPLICATE_API_TOKEN=

# Photo/image generation (if different from Replicate, add e.g. OPENAI_API_KEY or STABILITY_API_KEY)
# REPLICATE_API_TOKEN is often used for both video and image models
